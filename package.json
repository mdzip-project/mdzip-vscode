{
  "name": "mdzip-vscode",
  "displayName": "MDZip (.mdz) Editor",
  "description": "Read and write MDZip (.mdz) files including packaged images. Single document mode.",
  "version": "1.3.28",
  "icon": "media/icons/mdzip-marketplace-icon.png",
  "publisher": "mdzip-project",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/mdzip-project/mdzip-vscode"
  },
  "bugs": {
    "url": "https://github.com/mdzip-project/mdzip-vscode/issues"
  },
  "homepage": "https://github.com/mdzip-project/mdzip-vscode#readme",
  "engines": {
    "vscode": "^1.116.0"
  },
  "categories": [
    "Programming Languages",
    "Visualization",
    "AI",
    "Chat"
  ],
  "keywords": [
    "mdzip",
    "mdz",
    "markdown",
    "zip",
    "document"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "extensionDependencies": [
    "vscode.git"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "mcpServerDefinitionProviders": [
      {
        "id": "mdzip.bundled-mcp",
        "label": "MDZip MCP Server"
      }
    ],
    "languages": [
      {
        "id": "mdzip",
        "extensions": [
          ".mdz"
        ],
        "icon": {
          "light": "media/icons/mdzip-explorer-icon.svg",
          "dark": "media/icons/mdzip-explorer-icon.svg"
        }
      }
    ],
    "customEditors": [
      {
        "viewType": "mdzip.mdzEditor",
        "displayName": "MDZip Editor",
        "selector": [
          {
            "filenamePattern": "*.mdz"
          }
        ],
        "priority": "default"
      },
      {
        "viewType": "mdzip.mdEditor",
        "displayName": "MDZip Editor",
        "selector": [
          {
            "filenamePattern": "*.md"
          }
        ],
        "priority": "option"
      }
    ],
    "commands": [
      {
        "command": "mdzip.newFile",
        "title": "MDZip: New .mdz file...",
        "icon": {
          "light": "media/icons/mdzip-explorer-icon.svg",
          "dark": "media/icons/mdzip-explorer-icon.svg"
        }
      },
      {
        "command": "mdzip.configureTemplateFolder",
        "title": "MDZip: Configure Template Folder"
      },
      {
        "command": "mdzip.openTemplatesFolder",
        "title": "MDZip: Open Templates Folder"
      },
      {
        "command": "mdzip.convertMarkdownToMdz",
        "title": "MDZip: Convert .md To .mdz",
        "icon": {
          "light": "media/icons/mdzip-explorer-icon.svg",
          "dark": "media/icons/mdzip-explorer-icon.svg"
        }
      },
      {
        "command": "mdzip.compareMarkdown",
        "title": "MDZip: Compare Markdown"
      },
      {
        "command": "mdzip.compareWithGitBase",
        "title": "MDZip: Compare Document Markdown with Git Base"
      },
      {
        "command": "mdzip.compareArchiveWithGitBase",
        "title": "MDZip: Compare Archive Contents with Git Base"
      },
      {
        "command": "mdzip.copyMcpConfigSnippet",
        "title": "MDZip: Copy MCP Server Config Snippet"
      },
      {
        "command": "mdzip.enableWorkspaceMcp",
        "title": "MDZip: Enable Workspace MCP Server"
      },
      {
        "command": "mdzip.enableUserMcp",
        "title": "MDZip: Enable User MCP Server"
      },
      {
        "command": "mdzip.enableCodexMcp",
        "title": "MDZip: Enable Codex MCP Server"
      },
      {
        "command": "mdzip.openGettingStarted",
        "title": "MDZip: Open Getting Started"
      },
      {
        "command": "mdzip.openMcpServerStatus",
        "title": "MDZip: Open MCP Server Status"
      },
      {
        "command": "mdzip.openExtensionHelp",
        "title": "MDZip: Open Extension Help"
      },
      {
        "command": "mdzip.openDocumentation",
        "title": "MDZip: Open Documentation"
      },
      {
        "command": "mdzip.openWebsite",
        "title": "MDZip: Visit mdzip.org"
      },
      {
        "command": "mdzip.enableWorkspaceAgentInstructions",
        "title": "MDZip: Enable Workspace Agent Instructions"
      },
      {
        "command": "mdzip.extractToFolder",
        "title": "MDZip: Extract to Folder"
      },
      {
        "command": "mdzip.addAgentsGuide",
        "title": "MDZip: Add AGENTS.md to Archive",
        "icon": {
          "light": "media/icons/mdzip-explorer-icon.svg",
          "dark": "media/icons/mdzip-explorer-icon.svg"
        }
      }
    ],
    "configuration": {
      "title": "MDZip",
      "properties": {
        "mdzip.templates.path": {
          "type": "string",
          "default": "",
          "description": "Primary folder containing MDZip templates. Relative paths beginning with ./ or ../ resolve from the first workspace folder."
        },
        "mdzip.templates.additionalPaths": {
          "type": "array",
          "default": [],
          "items": {
            "type": "string"
          },
          "description": "Additional folders containing MDZip templates. Relative paths beginning with ./ or ../ resolve from the first workspace folder."
        }
      }
    },
    "menus": {
      "commandPalette": [
        {
          "command": "mdzip.newFile"
        },
        {
          "command": "mdzip.configureTemplateFolder"
        },
        {
          "command": "mdzip.openTemplatesFolder"
        },
        {
          "command": "mdzip.convertMarkdownToMdz"
        },
        {
          "command": "mdzip.compareMarkdown"
        },
        {
          "command": "mdzip.compareWithGitBase"
        },
        {
          "command": "mdzip.compareArchiveWithGitBase"
        },
        {
          "command": "mdzip.copyMcpConfigSnippet"
        },
        {
          "command": "mdzip.enableWorkspaceMcp"
        },
        {
          "command": "mdzip.enableUserMcp"
        },
        {
          "command": "mdzip.enableCodexMcp"
        },
        {
          "command": "mdzip.openGettingStarted"
        },
        {
          "command": "mdzip.openMcpServerStatus"
        },
        {
          "command": "mdzip.openExtensionHelp"
        },
        {
          "command": "mdzip.openDocumentation"
        },
        {
          "command": "mdzip.openWebsite"
        },
        {
          "command": "mdzip.enableWorkspaceAgentInstructions"
        },
        {
          "command": "mdzip.extractToFolder"
        },
        {
          "command": "mdzip.addAgentsGuide"
        }
      ],
      "explorer/context": [
        {
          "command": "mdzip.newFile",
          "when": "resourceScheme == file",
          "group": "navigation@10"
        },
        {
          "command": "mdzip.convertMarkdownToMdz",
          "when": "resourceExtname == .md",
          "group": "navigation@11"
        },
        {
          "command": "mdzip.compareMarkdown",
          "when": "resourceExtname == .mdz",
          "group": "navigation@12"
        },
        {
          "command": "mdzip.compareWithGitBase",
          "when": "resourceExtname == .mdz",
          "group": "navigation@13"
        },
        {
          "command": "mdzip.compareArchiveWithGitBase",
          "when": "resourceExtname == .mdz",
          "group": "navigation@14"
        },
        {
          "command": "mdzip.extractToFolder",
          "when": "resourceExtname == .mdz",
          "group": "navigation@15"
        },
        {
          "command": "mdzip.addAgentsGuide",
          "when": "resourceExtname == .mdz",
          "group": "navigation@16"
        }
      ],
      "editor/title": [
        {
          "command": "mdzip.convertMarkdownToMdz",
          "when": "resourceExtname == .md",
          "group": "navigation"
        },
        {
          "command": "mdzip.addAgentsGuide",
          "when": "resourceExtname == .mdz",
          "group": "navigation"
        }
      ],
      "editor/title/context": [
        {
          "command": "mdzip.convertMarkdownToMdz",
          "when": "resourceExtname == .md"
        },
        {
          "command": "mdzip.compareMarkdown",
          "when": "resourceExtname == .mdz"
        },
        {
          "command": "mdzip.compareWithGitBase",
          "when": "resourceExtname == .mdz"
        },
        {
          "command": "mdzip.compareArchiveWithGitBase",
          "when": "resourceExtname == .mdz"
        },
        {
          "command": "mdzip.extractToFolder",
          "when": "resourceExtname == .mdz"
        },
        {
          "command": "mdzip.addAgentsGuide",
          "when": "resourceExtname == .mdz"
        },
        {
          "command": "mdzip.copyMcpConfigSnippet",
          "when": "resourceExtname == .md || resourceExtname == .mdz"
        },
        {
          "command": "mdzip.enableWorkspaceMcp",
          "when": "resourceExtname == .md || resourceExtname == .mdz"
        },
        {
          "command": "mdzip.enableUserMcp",
          "when": "resourceExtname == .md || resourceExtname == .mdz"
        },
        {
          "command": "mdzip.enableCodexMcp",
          "when": "resourceExtname == .md || resourceExtname == .mdz"
        },
        {
          "command": "mdzip.openMcpServerStatus",
          "when": "resourceExtname == .md || resourceExtname == .mdz"
        },
        {
          "command": "mdzip.enableWorkspaceAgentInstructions",
          "when": "resourceExtname == .md || resourceExtname == .mdz"
        },
        {
          "command": "mdzip.openGettingStarted",
          "when": "resourceExtname == .md || resourceExtname == .mdz"
        },
        {
          "command": "mdzip.openExtensionHelp",
          "when": "resourceExtname == .md || resourceExtname == .mdz"
        },
        {
          "command": "mdzip.openDocumentation",
          "when": "resourceExtname == .md || resourceExtname == .mdz"
        },
        {
          "command": "mdzip.openWebsite",
          "when": "resourceExtname == .md || resourceExtname == .mdz"
        }
      ],
      "scm/resourceState/context": [
        {
          "command": "mdzip.compareWithGitBase",
          "when": "scmProvider == git",
          "group": "3_mdzip@1"
        },
        {
          "command": "mdzip.compareArchiveWithGitBase",
          "when": "scmProvider == git",
          "group": "3_mdzip@2"
        }
      ]
    },
    "walkthroughs": [
      {
        "id": "mdzip.gettingStarted",
        "title": "Get Started With MDZip",
        "description": "Open MDZip archives, trust the bundled MCP server when prompted, and optionally write shared or user MCP config.",
        "steps": [
          {
            "id": "mdzip.gettingStarted.openMdz",
            "title": "Open an .mdz file",
            "description": "Open any `.mdz` file to browse archive contents, preview images, and edit markdown entry points.",
            "completionEvents": [
              "onView:mdzip.mdzEditor"
            ]
          },
          {
            "id": "mdzip.gettingStarted.trustBundledMcp",
            "title": "Use the bundled MCP server",
            "description": "The bundled MDZip MCP server is auto-discovered. If VS Code prompts you to trust or start it, approve the prompt, then use [Open MCP Server Status](command:mdzip.openMcpServerStatus) to confirm it is available.",
            "completionEvents": [
              "onCommand:mdzip.openMcpServerStatus"
            ]
          },
          {
            "id": "mdzip.gettingStarted.workspaceMcp",
            "title": "Write workspace MCP config (optional)",
            "description": "Use [Enable Workspace MCP Server](command:mdzip.enableWorkspaceMcp) if you want a shared `.vscode/mcp.json` for the current workspace.",
            "completionEvents": [
              "onCommand:mdzip.enableWorkspaceMcp"
            ]
          },
          {
            "id": "mdzip.gettingStarted.manualSnippet",
            "title": "Copy manual MCP snippet (optional)",
            "description": "Use [Copy MCP Server Config Snippet](command:mdzip.copyMcpConfigSnippet) when you want to paste the config into a user or remote `mcp.json`.",
            "completionEvents": [
              "onCommand:mdzip.copyMcpConfigSnippet"
            ]
          },
          {
            "id": "mdzip.gettingStarted.userMcp",
            "title": "Write user MCP config (optional)",
            "description": "Use [Enable User MCP Server](command:mdzip.enableUserMcp) if you want the MDZip MCP server in your user-profile MCP configuration.",
            "completionEvents": [
              "onCommand:mdzip.enableUserMcp"
            ]
          },
          {
            "id": "mdzip.gettingStarted.extensionHelp",
            "title": "Reopen extension help",
            "description": "Use [Open Extension Help](command:mdzip.openExtensionHelp) to jump back to the extension details or Extensions view if you need the bundled MCP setup surface again.",
            "completionEvents": [
              "onCommand:mdzip.openExtensionHelp"
            ]
          },
          {
            "id": "mdzip.gettingStarted.docs",
            "title": "Open MDZip documentation",
            "description": "Use [Open Documentation](command:mdzip.openDocumentation) to open MDZip docs in your browser.",
            "completionEvents": [
              "onCommand:mdzip.openDocumentation"
            ]
          },
          {
            "id": "mdzip.gettingStarted.website",
            "title": "Visit mdzip.org",
            "description": "Use [Visit mdzip.org](command:mdzip.openWebsite) to open the main MDZip website.",
            "completionEvents": [
              "onCommand:mdzip.openWebsite"
            ]
          },
          {
            "id": "mdzip.gettingStarted.agentInstructions",
            "title": "Enable workspace agent instructions (optional)",
            "description": "Use [Enable Workspace Agent Instructions](command:mdzip.enableWorkspaceAgentInstructions) to write `.github/copilot-instructions.md` guidance that nudges agents to use `mdz_review_document` first for `.mdz` review tasks.",
            "completionEvents": [
              "onCommand:mdzip.enableWorkspaceAgentInstructions"
            ]
          }
        ]
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run bundle",
    "bundle": "npm run bundle:extension && npm run bundle:webview && npm run bundle:diff-webview && npm run bundle:mcp",
    "bundle:extension": "esbuild src/extension.ts --bundle --outfile=dist/extension.js --external:vscode --alias:jsdom=./src/jsdomStub.js --format=cjs --platform=node --minify",
    "bundle:webview": "esbuild src/webviewEditor.ts --bundle --outfile=media/editor.bundle.js --format=iife --platform=browser --minify",
    "bundle:diff-webview": "esbuild src/webviewDiff.ts --bundle --outfile=media/diff.bundle.js --format=iife --platform=browser --minify",
    "bundle:mcp": "esbuild src/mdzMcpServer.ts --bundle --outfile=dist/mdz-mcp-server.js --format=cjs --platform=node --minify",
    "test:editor": "npm --prefix ../mdzip-editor/packages/editor test",
    "test:mcp-smoke": "npm run bundle:mcp && node tests/mcp-smoke.cjs",
    "bundle:test-document": "esbuild src/mdzDocument.ts --bundle --outfile=dist/test/mdzDocument.cjs --alias:vscode=./tests/vscode-mock.cjs --alias:jsdom=./src/jsdomStub.js --format=cjs --platform=node",
    "test:document": "npm run bundle:test-document && node --test tests/mdzDocument.test.cjs",
    "compile": "tsc -p ./",
    "compile:integration": "tsc -p tsconfig.integration.json",
    "watch": "esbuild src/extension.ts --bundle --outfile=dist/extension.js --external:vscode --alias:jsdom=./src/jsdomStub.js --format=cjs --platform=node --watch",
    "lint": "eslint src --ext ts",
    "test": "npm run test:editor && npm run test:mcp-smoke && npm run test:document",
    "test:integration": "npm run bundle && npm run compile:integration && node dist/integration/runTests.js"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "^20.19.39",
    "@types/vscode": "^1.116.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "esbuild": "^0.28.0",
    "typescript": "^5.9.3",
    "vsce": "^2.15.0"
  },
  "dependencies": {
    "@mdzip/core-js": "^1.3.3",
    "@mdzip/editor": "^1.3.15",
    "@modelcontextprotocol/sdk": "^1.17.4",
    "jsdom": "^29.1.1",
    "marked": "^15.0.12",
    "mermaid": "^11.15.0"
  }
}
